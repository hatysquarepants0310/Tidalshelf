# Clave gratuita: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Secreto para firmar las cookies de sesión (>= 32 caracteres aleatorios).
# Genéralo por ejemplo con: openssl rand -base64 32
SESSION_SECRET=

# Ruta del archivo SQLite (opcional, por defecto ./data/tidalshelf.db)
# DATABASE_PATH=./data/tidalshelf.db
