# Clave gratuita: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Tu usuario de Last.fm (el que tiene conectado SOLO Tidal, no Spotify)
LASTFM_USERNAME=

# Ruta al archivo de autenticación de YT Music (generado con `ytmusicapi browser`)
# YTMUSIC_AUTH=./browser.json

# Cada cuántos segundos revisar Last.fm (por defecto 90)
# POLL_SECONDS=90

# Umbral de similitud para aceptar un match (0-1, por defecto 0.72)
# MATCH_THRESHOLD=0.72
